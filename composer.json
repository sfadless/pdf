{
  "name": "sfadless/pdf",
  "description": "Create PDF files from Twig templates",
  "license": "proprietary",
  "type": "library",
  "keywords": ["pdf", "twig", "mpdf", "html-to-pdf"],
  "authors": [
    {
      "name": "Pavel Golikov",
      "email": "pgolikov327@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "mpdf/mpdf": "^8.2.2",
    "twig/twig": "^3.8",
    "psr/event-dispatcher": "^1.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.0",
    "symfony/event-dispatcher": "^6.4 || ^7.0 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "Sfadless\\Pdf\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sfadless\\Pdf\\Test\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix"
  }
}
